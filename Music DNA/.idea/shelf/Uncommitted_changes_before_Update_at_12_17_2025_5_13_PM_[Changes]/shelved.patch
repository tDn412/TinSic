+                Log.d(TAG, "Đã lấy dữ liệu từ collection 'users' thành công:") // Log chung
+                if (result.isEmpty) {
+                    Log.d(TAG, "Collection 'users' không có tài liệu nào.")
+                } else {
+                    for (document in result) {
+                        // document.id là ID của tài liệu
+                        // document.data là dữ liệu dạng Map<String, Any>
+                        Log.d(TAG, "  ID: ${document.id} => Dữ liệu: ${document.data}")
+                    }
+                }
+            }
+            .addOnFailureListener { exception ->
+                // In lỗi nếu có vấn đề khi lấy dữ liệu
